{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build:public",
  "outputDirectory": "frontend/apps/public-web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
